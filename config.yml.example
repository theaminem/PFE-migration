# ─── Authentification OpenStack ───────────────────────────────────────────────
openstack:
  auth_url:        "https://dash.cloud.cerist.dz:5000/v3"
  region:          "RegionOne"
  default_user:    "migration-user"
  default_project: "migration"

# ─── Réseau ───────────────────────────────────────────────────────────────────
network:
  external_network_id: "<ID-du-PublicNetwork-OpenStack>"
  api_ip:              "dash.cloud.cerist.dz"
  apache_floating_ip:  "<IP-flottante-allouée-pour-Apache>"
  private_subnet_cidr: "10.10.0.0/24"

# ─── Image de base ────────────────────────────────────────────────────────────
image:
  name: "ubuntu-noble-24.04-amd64"

# ─── SSH ──────────────────────────────────────────────────────────────────────
ssh:
  key_path: "~/.ssh/migration_key"
  user:     "ubuntu"

# ─── Répertoire de staging sur les instances distantes ────────────────────────
staging_dir: "/tmp/migration"

# ─── Flavors par service ──────────────────────────────────────────────────────
flavors:
  mariadb: "m1.small"
  apache:  "m1.small"
  nfs:     "m1.small"
  ftp:     "m1.small"
  backup:  "m1.small"
  default: "m1.small"
